{
	"name": "opencode-plugin-flow",
	"version": "0.1.10",
	"description": "Stateful planning and execution workflow plugin for OpenCode",
	"type": "module",
	"main": "dist/index.js",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outfile ./dist/index.js --target node",
		"deadcode": "knip --include files,dependencies",
		"lint": "bunx biome check . --files-ignore-unknown=true --vcs-use-ignore-file=true",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"check": "bun run typecheck && bun run deadcode && bun run test && bun run build && bun run lint",
		"install:opencode": "bun run ./src/install-opencode.ts",
		"uninstall:opencode": "bun run ./src/uninstall-opencode.ts"
	},
	"keywords": [
		"opencode",
		"plugin",
		"workflow",
		"planning",
		"execution"
	],
	"author": "Douwe de Vries",
	"license": "MIT",
	"peerDependencies": {
		"@opencode-ai/plugin": "^1.3.10"
	},
	"dependencies": {
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@opencode-ai/plugin": "^1.3.10",
		"@biomejs/biome": "^2.2.6",
		"bun-types": "latest",
		"knip": "^5.63.1",
		"typescript": "^6.0.2"
	}
}
